# Cronometer account credentials (required)
CRONOMETER_USERNAME=
CRONOMETER_PASSWORD=

# --- Remote (HTTP) transport only; not needed for stdio ---
# MCP_TRANSPORT=streamable-http
# Long random secret; the bearer token Claude.ai uses after OAuth.
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# MCP_AUTH_TOKEN=
# Client credentials you configure in the Claude.ai custom connector.
# MCP_OAUTH_CLIENT_ID=
# MCP_OAUTH_CLIENT_SECRET=
# Public base URL of the deployment (e.g. https://your-app.up.railway.app)
# MCP_BASE_URL=
